# ==============================================================================
# File: .env.example
# Purpose: Template environment variables file for local development.
# Fits into: Configuration management. Use to scaffold your own local .env file.
# NOTE: Never commit actual secret keys or credentials to public repositories.
# ==============================================================================

# Binance API Credentials (Read-only API access is sufficient for paper trading)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# Firebase Admin SDK Configuration
# This should be the raw single-line or multi-line JSON string representing your service account key.
# For example: {"type": "service_account", "project_id": "...", ...}
FIREBASE_CREDENTIALS={"type": "service_account", "project_id": "crypto-bot-12345", "private_key": "-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQDh...\n-----END PRIVATE KEY-----\n", "client_email": "firebase-adminsdk-xxxxx@crypto-bot-12345.iam.gserviceaccount.com"}

# Telegram Bot Alerts Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# CryptoPanic API Token (Optional news aggregator)
CRYPTOPANIC_TOKEN=your_cryptopanic_token_here

# Groq API Credentials (Phase 2 Sentiment Analysis)
GROQ_API_KEY=your_groq_api_key_here

# Bot Operation Parameters
PORT=8000
ENVIRONMENT=development
